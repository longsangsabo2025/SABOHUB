# Supabase
SUPABASE_URL=https://dqddxowyikefqcdiioyh.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Blockchain
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# Contract Addresses (from deployments.json after deploy)
SABO_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
SABO_BRIDGE_ADDRESS=0x0000000000000000000000000000000000000000

# Bridge Service
PORT=3001
POLL_INTERVAL_MS=15000
MAX_RETRIES=3

# Daily Limits
MAX_DAILY_WITHDRAW_TOTAL=50000
MAX_SINGLE_WITHDRAW=10000
